{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "targetDefaults": {
    "build": {
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/public/**/*",
        "{projectRoot}/wxt.config.ts",
        "{projectRoot}/package.json",
        "{projectRoot}/pnpm-lock.yaml",
        "{projectRoot}/tsconfig.json",
        "{projectRoot}/postcss.config.cjs",
        "{projectRoot}/vitest.setup.ts"
      ],
      "outputs": ["{projectRoot}/.output/chrome-mv3", "{projectRoot}/.wxt"]
    },
    "build:firefox": {
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/public/**/*",
        "{projectRoot}/wxt.config.ts",
        "{projectRoot}/package.json",
        "{projectRoot}/pnpm-lock.yaml",
        "{projectRoot}/tsconfig.json",
        "{projectRoot}/postcss.config.cjs",
        "{projectRoot}/vitest.setup.ts"
      ],
      "outputs": ["{projectRoot}/.output/firefox-mv3", "{projectRoot}/.wxt"]
    },
    "test": {
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/vitest.*.ts",
        "{projectRoot}/tsconfig.json"
      ]
    },
    "test:cov": {
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/vitest.*.ts",
        "{projectRoot}/tsconfig.json"
      ],
      "outputs": ["{projectRoot}/coverage"]
    },
    "fmt:check": {
      "cache": true,
      "inputs": [
        "{projectRoot}/**/*.{js,jsx,ts,tsx,cjs,mjs,json,jsonc,css,md,yml,yaml}",
        "!{projectRoot}/node_modules/**",
        "!{projectRoot}/.wxt/**",
        "!{projectRoot}/.output/**",
        "!{projectRoot}/coverage/**",
        "!{projectRoot}/dist/**",
        "!{projectRoot}/.nx/**",
        "!{projectRoot}/.turbo/**",
        "!{projectRoot}/repos/**",
        "!{projectRoot}/scripts/output/**",
        "!{projectRoot}/.agents/**",
        "!{projectRoot}/.claude/**",
        "!{projectRoot}/.codex/**",
        "!{projectRoot}/.cursor/**",
        "{projectRoot}/.oxfmtrc.json",
        "{projectRoot}/package.json",
        "{projectRoot}/pnpm-lock.yaml"
      ]
    },
    "lint": {
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/.oxlintrc.json",
        "{projectRoot}/.oxfmtrc.json",
        "{projectRoot}/package.json",
        "{projectRoot}/pnpm-lock.yaml",
        "{projectRoot}/tsconfig.json"
      ]
    },
    "type-check": {
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/.oxlintrc.json",
        "{projectRoot}/package.json",
        "{projectRoot}/pnpm-lock.yaml",
        "{projectRoot}/tsconfig.json"
      ]
    }
  }
}
